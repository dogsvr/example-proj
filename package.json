{
  "name": "example-proj",
  "version": "0.1.0",
  "private": true,
  "description": "",
  "exports": {
    "./protocols/*": {
      "types": "./dist/protocols/*.d.ts",
      "default": "./dist/protocols/*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && copyfiles -u 1 \"src/*/*.json\" dist",
    "start": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop ecosystem.config.js",
    "restart": "pm2 restart ecosystem.config.js",
    "reload": "pm2 reload ecosystem.config.js",
    "delete": "pm2 delete ecosystem.config.js",
    "logs": "pm2 logs --lines 100 --raw | pino-pretty -t \"SYS:yyyy-mm-dd HH:MM:ss.l\" -i hostname",
    "status": "pm2 ls",
    "ops": "node dist/scripts/ops.js",
    "pack": "node dist/scripts/pack.js",
    "linkDog": "npm link @dogsvr/dogsvr @dogsvr/cl-tsrpc @dogsvr/cl-grpc @dogsvr/cfg-luban @dogsvr/logger"
  },
  "author": "rowanzhu",
  "license": "MIT",
  "dependencies": {
    "@dogsvr/cfg-luban": "^0.4.0",
    "@dogsvr/cl-grpc": "^0.4.0",
    "@dogsvr/cl-tsrpc": "^0.4.0",
    "@dogsvr/dogsvr": "^0.4.0",
    "@dogsvr/logger": "^0.4.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.8.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@redis/client": "^5.12.1",
    "colyseus": "^0.17.10",
    "example-proj-cfg": "file:../example-proj-cfg",
    "matter-js": "^0.20.0",
    "mongodb": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "copyfiles": "^2.4.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3"
  }
}
