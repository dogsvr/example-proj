{
    "workerThreadRunFile": "./dir_logic.js",
    "workerThreadNum": 2,
    "workerConfigPath": "./worker_thread_config.json",
    "log": {
        "level": "trace",
        "mode": "inline"
    },
    "cl": {
        "tsrpc": { "type": "tsrpc", "svrType": "http", "port": 10000 }
    },
    "otel": {
        "metrics": {
            "enabled": true,
            "sampleIntervalMs": 1000,
            "cmdDuration": true,
            "txnPending": true,
            "workerPending": true,
            "samplingRate": 1.0
        },
        "traces": {
            "enabled": true,
            "endpoint": "http://localhost:4318/v1/traces"
        },
        "logs": {
            "enabled": false
        }
    }
}
