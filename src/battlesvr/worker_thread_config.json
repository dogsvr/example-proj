{
    "log": {
        "level": "trace"
    },
    "colyseusPort": 30040,
    "otel": {
        "metrics": {
            "enabled": true,
            "mongo": { "enabled": false },
            "redis": { "enabled": false },
            "colyseus": {
                "tickDuration": true,
                "roomCount": true,
                "roomClients": true,
                "broadcastBytes": false,
                "broadcastCount": true
            },
            "logEvents": true,
            "threadStats": { "heap": true, "elu": true, "gc": true },
            "cmdHdl": true
        },
        "traces": {
            "enabled": true,
            "endpoint": "http://localhost:4318/v1/traces"
        }
    },
    "profiling": {
        "enabled": false,
        "endpoint": "http://127.0.0.1:4040",
        "samplingIntervalMicros": 10000,
        "appName": "example-proj"
    }
}
