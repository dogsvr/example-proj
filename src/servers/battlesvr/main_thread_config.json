{
    "workerThreadRunFile": "./battlesvr_logic.js",
    "workerThreadNum": 1,
    "workerConfigPath": "./worker_thread_config.json",
    "channel": { "msg": { "transport": "sab" } },
    "log": {
        "level": "trace",
        "mode": "central",
        "channel": { "transport": "sab" }
    },
    "cl": {
        "grpc": { "type": "grpc", "port": 30001 }
    },
    "clc": {
        "zonesvr": { "type": "grpc", "address": "127.0.0.1:20001" }
    },
    "otel": {
        "metrics": {
            "enabled": true,
            "sampleIntervalMs": 1000,
            "cmdDuration": true,
            "txnPending": true,
            "workerPending": true,
            "samplingRate": 1.0,
            "threadStats": { "enabled": true }
        },
        "traces": {
            "enabled": true,
            "endpoint": "http://localhost:4318/v1/traces"
        },
        "logs": {
            "enabled": true,
            "endpoint": "http://localhost:4318/v1/logs",
            "level": "trace"
        }
    },
    "profiling": {
        "enabled": false,
        "endpoint": "http://127.0.0.1:4040",
        "samplingIntervalMicros": 10000,
        "appName": "example-proj"
    }
}
