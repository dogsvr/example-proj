{
    "workerThreadRunFile": "./zonesvr_logic.js",
    "workerThreadNum": 2,
    "workerConfigPath": "./worker_thread_config.json",
    "channel": { "msg": { "transport": "postMessage" } },
    "log": {
        "level": "trace",
        "mode": "central",
        "channel": { "transport": "postMessage" }
    },
    "cl": {
        "tsrpc": { "type": "tsrpc", "svrType": "ws", "port": 20000, "log": { "level": "error", "body": false } },
        "grpc": { "type": "grpc", "port": 20001 }
    },
    "clc": {
        "battlesvr": { "type": "grpc", "address": "127.0.0.1:30001" }
    },
    "otel": {
        "metrics": {
            "enabled": true,
            "sampleIntervalMs": 1000,
            "cmdDuration": true,
            "txnPending": true,
            "workerPending": true,
            "samplingRate": 1.0,
            "threadStats": { "enabled": true }
        },
        "traces": {
            "enabled": false,
            "endpoint": "http://localhost:4318/v1/traces"
        },
        "logs": {
            "enabled": false,
            "endpoint": "http://localhost:4318/v1/logs",
            "level": "info"
        }
    },
    "profiling": {
        "enabled": true,
        "endpoint": "http://127.0.0.1:4040",
        "samplingIntervalMicros": 10000,
        "appName": "example-proj"
    }
}
