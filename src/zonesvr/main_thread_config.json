{
    "workerThreadRunFile": "./zonesvr_logic.js",
    "workerThreadNum": 2,
    "workerConfigPath": "./worker_thread_config.json",
    "log": {
        "level": "trace",
        "mode": "central"
    },
    "cl": {
        "tsrpc": { "type": "tsrpc", "svrType": "ws", "port": 20000, "log": { "level": "debug", "body": true } },
        "grpc": { "type": "grpc", "port": 20001 }
    },
    "clc": {
        "battlesvr": { "type": "grpc", "address": "127.0.0.1:30001" }
    },
    "otel": {
        "metrics": {
            "enabled": true,
            "sampleIntervalMs": 1000,
            "cmdDuration": true,
            "txnPending": true,
            "workerPending": true,
            "samplingRate": 1.0
        },
        "traces": {
            "enabled": true,
            "endpoint": "http://localhost:4318/v1/traces"
        },
        "logs": {
            "enabled": true,
            "endpoint": "http://localhost:4318/v1/logs",
            "level": "trace"
        }
    }
}
