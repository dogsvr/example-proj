{
    "log": {
        "level": "trace"
    },
    "mongoUri": "mongodb://127.0.0.1:27017",
    "redisUri": "redis://127.0.0.1:6379",
    "cfgDbPath": "../../../example-proj-cfg/dist/db",
    "tableKeysPath": "../../../example-proj-cfg/dist/table_keys.json",
    "otel": {
        "metrics": {
            "enabled": true,
            "mongo": { "enabled": true, "samplingRate": 1.0 },
            "redis": { "enabled": true, "samplingRate": 1.0 },
            "logEvents": true,
            "threadStats": { "heap": true, "elu": true, "gc": true },
            "cmdHdl": true
        },
        "traces": {
            "enabled": false,
            "endpoint": "http://localhost:4318/v1/traces"
        }
    },
    "profiling": {
        "enabled": true,
        "endpoint": "http://127.0.0.1:4040",
        "samplingIntervalMicros": 10000,
        "appName": "example-proj"
    }
}
